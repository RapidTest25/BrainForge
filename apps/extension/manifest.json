{
  "manifest_version": 3,
  "name": "BrainForge Meet Assistant",
  "version": "1.0.0",
  "description": "AI-powered meeting assistant for Google Meet. Record, transcribe, and summarize meetings directly in Meet with BrainForge.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://meet.google.com/*/",
    "http://localhost:4000/*",
    "http://localhost:3000/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "BrainForge Meet Assistant"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "src/content-script.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected-script.js"
      ],
      "matches": [
        "https://meet.google.com/*"
      ]
    }
  ]
}
